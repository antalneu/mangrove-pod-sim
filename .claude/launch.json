{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "mangrove-web",
      "runtimeExecutable": ".venv/Scripts/python.exe",
      "runtimeArgs": ["webapp/app.py"],
      "port": 5000
    },
    {
      "name": "docs-site",
      "runtimeExecutable": ".venv/Scripts/python.exe",
      "runtimeArgs": ["-m", "http.server", "8000", "--directory", "docs"],
      "port": 8000
    },
    {
      "name": "docs-app",
      "runtimeExecutable": ".venv/Scripts/python.exe",
      "runtimeArgs": ["serve_docs.py"],
      "port": 8010
    }
  ]
}
